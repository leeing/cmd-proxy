# Required: upstream API key
CMD_API_KEY=

# Optional: upstream API base URL (default: https://api.commandcode.ai)
# CMD_API_BASE=https://api.commandcode.ai

# Optional: Proxy port (default: 8888)
# CMD_PROXY_PORT=8888

# Optional: Inject memory / taste context for agent sessions
# CMD_PROXY_MEMORY=
# CMD_PROXY_TASTE=

# Optional: Auth mode (default: pass_through)
#   pass_through = validate client key matches CMD_API_KEY
#   fixed        = always use CMD_API_KEY regardless of client
#   none         = no auth check
# CMD_PROXY_AUTH_MODE=pass_through

# Optional: Log level (default: info)
# LOG_LEVEL=info

# Optional: Upstream request timeout in ms (default: 300000 = 5min)
# CMD_PROXY_UPSTREAM_TIMEOUT_MS=300000
