# Required: Command Code API key
COMMANDCODE_API_KEY=

# Optional: Command Code API base URL (default: https://api.commandcode.ai)
# COMMANDCODE_API_BASE=https://api.commandcode.ai

# Optional: Proxy port (default: 8888)
# CMD_PROXY_PORT=8888

# Optional: Auth mode (default: pass_through)
#   pass_through = forward client's Bearer token as upstream API key
#   fixed        = always use COMMANDCODE_API_KEY regardless of client
#   none         = no auth check
# CMD_PROXY_AUTH_MODE=pass_through

# Optional: Log level (default: info)
# LOG_LEVEL=info
