# Required: upstream API key
CMD_API_KEY=

# Optional: upstream API base URL (default: https://api.commandcode.ai)
# CMD_API_BASE=https://api.commandcode.ai

# Optional: Proxy port (default: 8888)
# CMD_PROXY_PORT=8888

# Optional: Inject memory / taste context for agent sessions
# CMD_PROXY_MEMORY=
# CMD_PROXY_TASTE=

# Optional: Auth mode (default: pass_through)
#   pass_through = validate client key matches CMD_API_KEY
#   fixed        = always use CMD_API_KEY regardless of client
#   none         = no auth check
# CMD_PROXY_AUTH_MODE=pass_through

# Optional: Log level (default: info)
# LOG_LEVEL=info

# Optional: Upstream request timeout in ms (default: 300000 = 5min)
# CMD_PROXY_UPSTREAM_TIMEOUT_MS=300000

# Optional: CLI identity headers sent to upstream (defaults shown)
# CMD_PROXY_CLI_VERSION=0.24.1
# CMD_PROXY_CLI_ENVIRONMENT=production
# CMD_PROXY_TASTE_LEARNING=false
# CMD_PROXY_CO_FLAG=false

# Optional: Custom model alias map (format: alias1=upstream1;alias2=upstream2)
# CMD_PROXY_MODEL_MAP=

# Optional: Default model when client doesn't specify one (default: deepseek-v4-pro)
# CMD_PROXY_DEFAULT_MODEL=deepseek-v4-pro

# Optional: Default max tokens for Chat Completions / Responses (default: 32000)
# CMD_PROXY_MAX_TOKENS=32000

# Optional: Default max tokens for Anthropic Messages API (default: 4096)
# CMD_PROXY_MAX_TOKENS_ANTHROPIC=4096

# Optional: Hard cap on max tokens regardless of client request (default: 200000)
# CMD_PROXY_MAX_TOKENS_CAP=200000

# Optional: Anthropic API version header (default: 2023-06-01)
# CMD_PROXY_ANTHROPIC_API_VERSION=2023-06-01

# Optional: Upstream generate endpoint path (default: /alpha/generate)
# CMD_PROXY_UPSTREAM_PATH=/alpha/generate

# Optional: owned_by field in /v1/models response (default: commandcode)
# CMD_PROXY_MODEL_OWNED_BY=commandcode
